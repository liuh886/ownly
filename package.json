{
  "name": "wyqd-app",
  "version": "1.0.6",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "node scripts/gen-git-sha.mjs && next dev",
    "build": "node scripts/gen-git-sha.mjs && next build",
    "build:obsidian": "node scripts/gen-git-sha.mjs && node esbuild.obsidian.mjs --production",
    "check:obsidian": "tsc -p tsconfig.obsidian.json --pretty false",
    "lint:obsidian": "eslint \"src/obsidian/\"",
    "build:all": "npm run build && npm run build:obsidian",
    "package:obsidian": "npm run build:obsidian && node scripts/package-obsidian-plugin.mjs",
    "validate:obsidian": "npm run check:obsidian && npm run lint:obsidian && npm run package:obsidian && node scripts/validate-obsidian-release.mjs",
    "validate": "node scripts/gen-git-sha.mjs && tsc --noEmit && npm run lint && npm run build && npm run validate:obsidian",
    "smoke:install": "python -m pip install -r requirements-smoke.txt && python -m playwright install chromium",
    "smoke:web": "python tests/smoke/web_smoke.py",
    "smoke:site": "python tests/smoke/site_functionality.py",
    "test:e2e": "npm run smoke:web && npm run smoke:site",
    "deps:reset": "node -e \"require('node:fs').rmSync('node_modules',{recursive:true,force:true})\" && npm ci",
    "wyqd": "tsx scripts/wyqd-cli.ts",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "framer-motion": "^12.41.0",
    "idb-keyval": "^6.2.5",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "topojson-client": "^3.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.13.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "description": "Local-first Obsidian decision ledger for possessions, subscriptions, and experiences."
}
