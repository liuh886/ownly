{
  "name": "wyqd-app",
  "version": "1.0.4",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:obsidian": "node esbuild.obsidian.mjs --production",
    "check:obsidian": "tsc -p tsconfig.obsidian.json --pretty false",
    "build:all": "npm run build && npm run build:obsidian",
    "package:obsidian": "npm run build:obsidian && node scripts/package-obsidian-plugin.mjs",
    "validate:obsidian": "npm run check:obsidian && npm run package:obsidian && node scripts/validate-obsidian-release.mjs",
    "validate": "tsc --noEmit && npm run lint && npm run build && npm run validate:obsidian",
    "smoke:install": "python -m pip install -r requirements-smoke.txt && python -m playwright install chromium",
    "smoke:web": "python tests/smoke/web_smoke.py",
    "smoke:site": "python tests/smoke/site_functionality.py",
    "test:e2e": "npm run smoke:web && npm run smoke:site",
    "deps:reset": "node -e \"require('node:fs').rmSync('node_modules',{recursive:true,force:true})\" && npm ci",
    "wyqd": "tsx scripts/wyqd-cli.ts",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "framer-motion": "^12.38.0",
    "idb-keyval": "^6.2.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "topojson-client": "^3.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/topojson-client": "^3.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.12.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3"
  },
  "description": "[![Obsidian Plugin](https://img.shields.io/badge/Obsidian-Plugin-blue?logo=obsidian)](https://obsidian.md/plugins?id=ownly)\r [![Status](https://img.shields.io/badge/status-stable_1.x-brightgreen.svg)](CHANGELOG.md)\r [![License: MIT](https://img.shields.io/badge/License-MIT-green.svg)](LICENSE)\r [![Ko-fi](https://ko-fi.com/img/githubbutton_sm.svg)](https://ko-fi.com/F1F7WYJ6B)",
  "main": "main.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liuh886/ownly.git"
  },
  "keywords": [],
  "author": "",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/liuh886/ownly/issues"
  },
  "homepage": "https://github.com/liuh886/ownly#readme"
}
