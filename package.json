{
  "name": "wyqd-app",
  "version": "0.2.3",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:obsidian": "node esbuild.obsidian.mjs --production",
    "check:obsidian": "tsc -p tsconfig.obsidian.json --pretty false",
    "build:all": "npm run build && npm run build:obsidian",
    "package:obsidian": "npm run build:obsidian && node scripts/package-obsidian-plugin.mjs",
    "validate:obsidian": "npm run check:obsidian && npm run package:obsidian && node scripts/validate-obsidian-release.mjs",
    "validate": "npm exec tsc -- --noEmit && npm run lint && npm run build && npm run validate:obsidian",
    "deps:reset": "node -e \"require('node:fs').rmSync('node_modules',{recursive:true,force:true})\" && npm ci",
    "wyqd": "node scripts/wyqd-cli.mjs",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "idb-keyval": "^6.2.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "obsidian": "^1.12.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
